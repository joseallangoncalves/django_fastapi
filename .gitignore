# ==============================================================================
#                      ARQUIVOS IGNORADOS PELO GIT
# ==============================================================================

# --- Segurança e Credenciais (MUITO IMPORTANTE) ---
# Ignora arquivos de ambiente que contêm chaves de API do Groq, chaves secretas JWT, etc.
.env
.env.*
!.env.sample
backend/.env
backend/.env.*
!backend/.env.sample
frontend/.env
frontend/.env.*

# --- Banco de Dados Local (SQLite) ---
# Ignora os arquivos de banco de dados SQLite físicos e arquivos temporários/locks de escrita
*.db
*.db-journal
*.db-shm
*.db-wal
backend/*.db
backend/*.db-journal
backend/pos_sistema.db
frontend/*.db
db.sqlite3

# --- Ambientes Virtuais ---
# Ignora pastas de ambientes virtuais do Python
.venv/
venv/
env/
ENV/
Active_Resources/

# --- Compilados do Python e Caches ---
# Ignora arquivos compilados e caches para manter o repositório limpo
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# --- Configurações de IDEs e Editores ---
# Ignora configurações específicas de editores (VS Code, PyCharm, etc.)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# --- Arquivos de Sistema Operacional ---
# Ignora lixo gerado pelo Windows e macOS
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
